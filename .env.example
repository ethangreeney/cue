# Copy this file to .env.local and fill in real values.

# --- Gemini (Google AI Studio) ---
# Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# Target model. gemini-3.5-flash is the intended model; if unavailable on your
# account, use the closest Flash model (e.g. gemini-2.5-flash) and note it.
GEMINI_MODEL=gemini-3.5-flash

# --- Spotify (Web API, Authorization Code flow) ---
# Create an app at https://developer.spotify.com/dashboard
# Add this exact Redirect URI to the app settings.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Base URL the app runs on. Spotify requires the loopback IP (127.0.0.1),
# not "localhost", for http redirect URIs.
APP_BASE_URL=http://127.0.0.1:8888
